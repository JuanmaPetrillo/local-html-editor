{
  "name": "local-html-editor",
  "private": true,
  "version": "0.1.0",
  "description": "Fully local HTML presentation editor scaffold",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "test": "node scripts/test.mjs",
    "test:e2e": "node scripts/test-e2e.mjs",
    "test:security": "node scripts/test-security.mjs",
    "build": "node scripts/build.mjs",
    "package:pilot": "node scripts/package-pilot.mjs",
    "test:v2": "node scripts/test-v2.mjs",
    "test:e2e:browser": "node scripts/test-e2e-browser.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
